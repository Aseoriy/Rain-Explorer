<UserControl
    x:Class="RainExplorer.Controls.DrivesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <UserControl.Resources>
        <!-- A clickable glass drive card -->
        <Style x:Key="DriveCard" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Glass2}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource Line2}" BorderThickness="1"
                                CornerRadius="12" Padding="18,16">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Glass3}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AccentLine}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,22,28,28">
        <StackPanel MaxWidth="720" HorizontalAlignment="Stretch">
            <TextBlock Text="Drives" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Text}" />
            <TextBlock Text="Storage usage across your drives." Foreground="{StaticResource TextMuted}"
                       Margin="0,4,0,18" />

            <ItemsControl ItemsSource="{Binding Drives}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource DriveCard}"
                                Command="{Binding DataContext.OpenEntryCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                                            Background="{StaticResource Glass3}" BorderBrush="{StaticResource Line2}"
                                            BorderThickness="1" VerticalAlignment="Center">
                                        <Path Style="{StaticResource IconPath}" Width="20" Height="20"
                                              Data="{Binding IconKey, Converter={StaticResource IconGeom}}"
                                              Stroke="{StaticResource AccentBright}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding TypeText}" FontSize="11"
                                                   Foreground="{StaticResource TextFaint}" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding CountText}" VerticalAlignment="Center"
                                               Foreground="{StaticResource TextMuted}" FontSize="12"
                                               FontFamily="{StaticResource MonoFont}" />
                                </Grid>

                                <!-- Usage bar -->
                                <ProgressBar Grid.Row="1" Style="{StaticResource UsageBar}"
                                             Value="{Binding UsedPercent}" Margin="0,16,0,0" />

                                <!-- Usage text (two columns so they can't overlap) -->
                                <Grid Grid.Row="2" Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding UsageText}" Foreground="{StaticResource TextMuted}"
                                               FontSize="12" FontFamily="{StaticResource MonoFont}"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                                    <TextBlock Grid.Column="1" Text="{Binding FreeText}"
                                               Foreground="{StaticResource AccentBright}" FontSize="12"
                                               FontFamily="{StaticResource MonoFont}" />
                                </Grid>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
