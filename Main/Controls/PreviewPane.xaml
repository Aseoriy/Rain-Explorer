<UserControl
    x:Class="RainExplorer.Controls.PreviewPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinWidth="240">

    <Border Background="{StaticResource Glass2}" BorderBrush="{StaticResource Line1}" BorderThickness="1,0,0,0">
        <DockPanel LastChildFill="True">
            <!-- Header: file name + close -->
            <Border DockPanel.Dock="Top" Padding="14,10"
                    BorderBrush="{StaticResource Line1}" BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                            Click="Close_Click" ToolTip="Hide preview (Space)">
                        <Path Style="{StaticResource IconPath}" Width="15" Height="15"
                              Data="{StaticResource Ic.x}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <TextBlock x:Name="NameText" VerticalAlignment="Center"
                               Foreground="{StaticResource Text}" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                </DockPanel>
            </Border>

            <!-- Footer: metadata line -->
            <Border DockPanel.Dock="Bottom" Padding="14,8"
                    BorderBrush="{StaticResource Line1}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="MetaText" Foreground="{StaticResource TextMuted}" FontSize="11"
                           TextTrimming="CharacterEllipsis" />
            </Border>

            <!-- Content: image / text / media / empty (visibility-switched) -->
            <Grid Margin="10">
                <Image x:Name="ImageView" Stretch="Uniform" Visibility="Collapsed"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <!-- Audio / video player -->
                <Grid x:Name="MediaView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <MediaElement x:Name="Media" LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                      ScrubbingEnabled="True" Stretch="Uniform"
                                      MediaOpened="Media_MediaOpened" MediaEnded="Media_MediaEnded"
                                      MediaFailed="Media_MediaFailed" />
                        <Path x:Name="AudioGlyph" Width="84" Height="84" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Data="{StaticResource Ic.music}" Stroke="{StaticResource TextFaint}"
                              StrokeThickness="1.2" Visibility="Collapsed" />
                    </Grid>
                    <Border Grid.Row="1" Background="{StaticResource Glass3}" CornerRadius="8"
                            Padding="8,5" Margin="0,10,0,0">
                        <DockPanel LastChildFill="True">
                            <Button x:Name="PlayPause" DockPanel.Dock="Left" Style="{StaticResource IconButton}"
                                    Click="PlayPause_Click" Margin="0,0,8,0">
                                <Path x:Name="PlayIcon" Style="{StaticResource IconPath}" Width="16" Height="16"
                                      Data="{StaticResource Ic.play}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Button>
                            <TextBlock x:Name="TimeText" DockPanel.Dock="Right" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMuted}" FontSize="11" Margin="8,0,2,0"
                                       FontFamily="{StaticResource MonoFont}" Text="0:00" />
                            <Slider x:Name="Seek" VerticalAlignment="Center" Minimum="0" Maximum="1"
                                    IsMoveToPointEnabled="True" ValueChanged="Seek_ValueChanged" />
                        </DockPanel>
                    </Border>
                </Grid>

                <ScrollViewer x:Name="TextScroll" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="TextView" IsReadOnly="True" BorderThickness="0"
                             Background="Transparent" Foreground="{StaticResource TextDim}"
                             FontFamily="{StaticResource MonoFont}" FontSize="12"
                             TextWrapping="NoWrap" IsReadOnlyCaretVisible="False" />
                </ScrollViewer>

                <!-- PDF page navigation -->
                <Border x:Name="PdfBar" Visibility="Collapsed" VerticalAlignment="Bottom"
                        HorizontalAlignment="Center" Margin="0,0,0,6"
                        Background="{StaticResource Glass4}" BorderBrush="{StaticResource Line2}"
                        BorderThickness="1" CornerRadius="8" Padding="4,3">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PdfPrev" Style="{StaticResource IconButton}" Click="PdfPrev_Click"
                                ToolTip="Previous page">
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.arrow-left}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </Button>
                        <TextBlock x:Name="PdfPage" VerticalAlignment="Center" Margin="8,0"
                                   Foreground="{StaticResource Text}" FontSize="12"
                                   FontFamily="{StaticResource MonoFont}" Text="1 / 1" />
                        <Button x:Name="PdfNext" Style="{StaticResource IconButton}" Click="PdfNext_Click"
                                ToolTip="Next page">
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.arrow-right}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </Button>
                    </StackPanel>
                </Border>

                <StackPanel x:Name="EmptyView" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Path x:Name="EmptyIcon" Width="60" Height="60" Stretch="Uniform"
                          Stroke="{StaticResource TextFaint}" StrokeThickness="1.3"
                          HorizontalAlignment="Center" Data="{StaticResource Ic.file}" />
                    <TextBlock x:Name="EmptyText" Foreground="{StaticResource TextFaint}"
                               Margin="0,14,0,0" HorizontalAlignment="Center" FontSize="13"
                               TextAlignment="Center" MaxWidth="220" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
