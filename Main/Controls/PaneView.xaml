<UserControl
    x:Class="RainExplorer.Controls.PaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="clr-namespace:RainExplorer.Services"
    xmlns:ctrl="clr-namespace:RainExplorer.Controls"
    Background="Transparent"
    Foreground="{StaticResource Text}"
    PreviewMouseDown="Root_PreviewMouseDown"
    PreviewKeyDown="Root_PreviewKeyDown">

    <UserControl.Resources>
        <!-- Browser-style folder tab: glass when active, violet underline + accent icon -->
        <Style x:Key="TabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="bg" Background="Transparent" CornerRadius="8,8,0,0"
                                    BorderBrush="Transparent" BorderThickness="1,1,1,0"
                                    Padding="10,6" MinWidth="124" MaxWidth="208">
                                <DockPanel LastChildFill="True">
                                    <Path x:Name="ico" DockPanel.Dock="Left" Style="{StaticResource IconPath}"
                                          Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"
                                          Data="{StaticResource Ic.folder}"
                                          Stroke="{StaticResource TextMuted}" />
                                    <Button x:Name="close" DockPanel.Dock="Right" Width="18" Height="18"
                                            Margin="6,0,0,0" Cursor="Hand" Background="Transparent"
                                            Foreground="{StaticResource TextFaint}"
                                            Command="{Binding DataContext.CloseTabCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}" ToolTip="Close tab (Ctrl+W)">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="cb" Background="{TemplateBinding Background}"
                                                        CornerRadius="4">
                                                    <Path Style="{StaticResource IconPath}" Width="11" Height="11"
                                                          StrokeThickness="2" Data="{StaticResource Ic.x}"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="cb" Property="Background" Value="{StaticResource Glass4}" />
                                                        <Setter Property="Foreground" Value="{StaticResource Text}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </Border>
                            <!-- violet underline on the active tab -->
                            <Border x:Name="ul" Height="2" CornerRadius="2" VerticalAlignment="Bottom"
                                    Margin="10,0" Background="{StaticResource GradientAccent}"
                                    Visibility="Collapsed">
                                <Border.Effect>
                                    <DropShadowEffect Color="#A855F7" BlurRadius="8" ShadowDepth="0" Opacity="0.7" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource Glass3}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource Glass3}" />
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource Line2}" />
                                <Setter TargetName="ico" Property="Stroke" Value="{StaticResource AccentBright}" />
                                <Setter TargetName="ul" Property="Visibility" Value="Visible" />
                                <Setter Property="Foreground" Value="{StaticResource Text}" />
                            </Trigger>
                            <!-- File drag hovering this tab: accent drop highlight -->
                            <DataTrigger Binding="{Binding IsDropTarget}" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentWash}" />
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentLine}" />
                                <Setter TargetName="ico" Property="Stroke" Value="{StaticResource AccentBright}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Muted mono cell text for date / type / size -->
        <Style x:Key="MetaCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <!-- Chrome-less text input (address / search): no border, no default
             chrome — just text + an optional Tag placeholder. -->
        <Style x:Key="BareBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBright}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentWash2}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <TextBlock x:Name="ph" Text="{TemplateBinding Tag}" Visibility="Collapsed"
                                       Foreground="{StaticResource TextFaint}" IsHitTestVisible="False"
                                       VerticalAlignment="Center" />
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="ph" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Alternate layouts (List / Tiles / Grid) ===== -->
        <ItemsPanelTemplate x:Key="IconWrapPanel">
            <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <!-- Selectable container for the icon layouts -->
        <Style x:Key="TileItemStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="9"
                                BorderBrush="Transparent" BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Glass3}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentWash}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AccentLine}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- List: compact icon + name -->
        <DataTemplate x:Key="ListItemTemplate">
            <StackPanel Orientation="Horizontal" Width="232" Margin="8,5">
                <Path Style="{StaticResource IconPath}" Width="16" Height="16" StrokeThickness="1.7"
                      Margin="0,0,9,0" VerticalAlignment="Center"
                      Data="{Binding IconKey, Converter={StaticResource IconGeom}}"
                      Stroke="{Binding IconBrush}" />
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                           Foreground="{StaticResource Text}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <!-- Tiles: medium icon + name + type, card-like -->
        <DataTemplate x:Key="TileTemplateMedium">
            <StackPanel Orientation="Horizontal" Width="216" Margin="10,8">
                <Path Style="{StaticResource IconPath}" Width="30" Height="30" StrokeThickness="1.6"
                      Margin="0,0,12,0" VerticalAlignment="Center"
                      Data="{Binding IconKey, Converter={StaticResource IconGeom}}"
                      Stroke="{Binding IconBrush}" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource Text}"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="150" />
                    <TextBlock Text="{Binding TypeLabel}" Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Grid: large icon over centered name -->
        <DataTemplate x:Key="TileTemplateLarge">
            <StackPanel Width="116" Margin="6,12" HorizontalAlignment="Center">
                <Path Style="{StaticResource IconPath}" Width="46" Height="46" StrokeThickness="1.4"
                      HorizontalAlignment="Center"
                      Data="{Binding IconKey, Converter={StaticResource IconGeom}}"
                      Stroke="{Binding IconBrush}" />
                <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource Text}"
                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,9,0,0"
                           TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="34"
                           MaxWidth="104" FontSize="12" />
            </StackPanel>
        </DataTemplate>

        <!-- Inline rename / new-folder editor: small frosted field with an accent edge. -->
        <Style x:Key="InlineEditBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource Glass3}" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBright}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentWash2}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentLine}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Tab strip -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" Margin="8,6,0,0" VerticalAlignment="Bottom">
                <ListBox x:Name="TabBar" ItemsSource="{Binding Tabs}"
                         SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource TabItemStyle}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         AllowDrop="True"
                         DragOver="TabBar_DragOver"
                         DragLeave="TabBar_DragLeave"
                         Drop="TabBar_Drop"
                         PreviewMouseDown="TabBar_PreviewMouseDown">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
                <Button Style="{StaticResource IconButton}" VerticalAlignment="Bottom" Margin="4,0,0,2"
                        Command="{Binding NewTabCommand}" ToolTip="New tab (Ctrl+T)">
                    <Path Style="{StaticResource IconPath}" Width="16" Height="16" Data="{StaticResource Ic.plus}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Navigation bar (scoped to the active tab) -->
        <Border Grid.Row="1" Background="Transparent"
                BorderBrush="{StaticResource Line1}" BorderThickness="0,0,0,1"
                Padding="12,8" DataContext="{Binding SelectedTab}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- nav buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Style="{StaticResource IconButton}" Command="{Binding BackCommand}" ToolTip="Back (Alt+Left)">
                        <Path Style="{StaticResource IconPath}" Width="17" Height="17" Data="{StaticResource Ic.arrow-left}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ForwardCommand}" ToolTip="Forward (Alt+Right)">
                        <Path Style="{StaticResource IconPath}" Width="17" Height="17" Data="{StaticResource Ic.arrow-right}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding UpCommand}" ToolTip="Up (Alt+Up)">
                        <Path Style="{StaticResource IconPath}" Width="17" Height="17" Data="{StaticResource Ic.arrow-up}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding RefreshCommand}" ToolTip="Refresh (F5)">
                        <Path Style="{StaticResource IconPath}" Width="16" Height="16" Data="{StaticResource Ic.refresh}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>

                <!-- Address bar: clickable breadcrumb that flips to an editable path box (Ctrl+L) -->
                <ctrl:BreadcrumbBar x:Name="AddressBar" Grid.Column="1" VerticalAlignment="Center" />

                <!-- Search pill: search glyph + filter + recursive toggle -->
                <Border Grid.Column="2" Width="210" Margin="8,0,0,0" Background="{StaticResource Glass2}"
                        BorderBrush="{StaticResource Line2}" BorderThickness="1" CornerRadius="8"
                        Height="30" VerticalAlignment="Center">
                    <DockPanel LastChildFill="True" Margin="10,0,2,0">
                        <Path DockPanel.Dock="Left" Style="{StaticResource IconPath}" Width="14" Height="14"
                              Margin="0,0,8,0" VerticalAlignment="Center"
                              Data="{StaticResource Ic.search}" Stroke="{StaticResource TextMuted}" />
                        <ToggleButton DockPanel.Dock="Right" Style="{StaticResource ToggleChip}"
                                      IsChecked="{Binding Recursive, Mode=TwoWay}"
                                      ToolTip="Search subfolders (recursive)">
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.recursive}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        </ToggleButton>
                        <TextBox x:Name="SearchBox" Style="{StaticResource BareBox}" Tag="Search"
                                 Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                </Border>

                <!-- Sort / View / Split -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="8,0,0,0">
                    <!-- Sort menu -->
                    <Button Style="{StaticResource IconButton}" Click="OpenButtonMenu_Click" ToolTip="Sort by">
                        <Path Style="{StaticResource IconPath}" Width="16" Height="16" Data="{StaticResource Ic.sliders}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Sort by" IsEnabled="False" FontWeight="SemiBold" />
                                <MenuItem Header="Name" Tag="Name" Click="Sort_Click" />
                                <MenuItem Header="Date modified" Tag="Modified" Click="Sort_Click" />
                                <MenuItem Header="Date created" Tag="Created" Click="Sort_Click" />
                                <MenuItem Header="Type" Tag="Type" Click="Sort_Click" />
                                <MenuItem Header="Size" Tag="Size" Click="Sort_Click" />
                                <Separator />
                                <MenuItem Header="Reverse order" Click="ReverseSort_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Layout menu -->
                    <Button Style="{StaticResource IconButton}" Margin="2,0,0,0"
                            Click="OpenButtonMenu_Click" ToolTip="Layout">
                        <Path Style="{StaticResource IconPath}" Width="16" Height="16" Data="{StaticResource Ic.list}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Layout" IsEnabled="False" FontWeight="SemiBold" />
                                <MenuItem Header="Details" Tag="Details" Click="Layout_Click" />
                                <MenuItem Header="List" Tag="List" Click="Layout_Click" />
                                <MenuItem Header="Tiles" Tag="Tiles" Click="Layout_Click" />
                                <MenuItem Header="Grid" Tag="Grid" Click="Layout_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Preview pane toggle -->
                    <ToggleButton Style="{StaticResource ToggleChip}" Margin="2,0,0,0"
                                  IsChecked="{Binding Source={x:Static svc:SettingsStore.Instance},
                                      Path=Settings.ShowPreviewPane, Mode=TwoWay}"
                                  ToolTip="Preview pane (Space)">
                        <Path Style="{StaticResource IconPath}" Width="16" Height="16" Data="{StaticResource Ic.eye}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                    </ToggleButton>

                    <!-- Split toggle -->
                    <Button Style="{StaticResource IconButton}" Margin="2,0,0,0"
                            Command="{Binding DataContext.ToggleSplitCommand,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Toggle split view">
                        <Path Style="{StaticResource IconPath}" Width="16" Height="16" Data="{StaticResource Ic.split}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" DataContext="{Binding SelectedTab}">
        <ctrl:HomeView Visibility="{Binding IsHomeView, Converter={StaticResource BoolToVis}}" />
        <ctrl:DrivesView Visibility="{Binding IsDrivesView, Converter={StaticResource BoolToVis}}" />
        <!-- Folder view: file list + marquee, with an optional preview pane on the right. -->
        <Grid Visibility="{Binding IsFolderView, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="240" />
                <ColumnDefinition x:Name="PreviewSplitterCol" Width="0" />
                <ColumnDefinition x:Name="PreviewCol" Width="0" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
        <ListView x:Name="FileList"
                  ItemsSource="{Binding Items}"
                  ItemContainerStyle="{StaticResource FileRowStyle}"
                  SelectionMode="Extended"
                  Background="Transparent" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  AllowDrop="True"
                  SelectionChanged="FileList_SelectionChanged"
                  MouseDoubleClick="FileList_MouseDoubleClick"
                  PreviewMouseDown="FileList_PreviewMouseDown"
                  PreviewMouseLeftButtonDown="FileList_PreviewMouseLeftButtonDown"
                  PreviewMouseRightButtonDown="FileList_PreviewMouseRightButtonDown"
                  MouseLeftButtonUp="FileList_MouseLeftButtonUp"
                  MouseMove="FileList_MouseMove"
                  LostMouseCapture="FileList_LostMouseCapture"
                  DragOver="FileList_DragOver"
                  DragLeave="FileList_DragLeave"
                  Drop="FileList_Drop"
                  KeyDown="FileList_KeyDown"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.RenderTransform>
                <TranslateTransform x:Name="ListTransform" Y="0" />
            </ListView.RenderTransform>
            <ListView.ContextMenu>
                <ContextMenu Opened="FileContextMenu_Opened" Closed="FileContextMenu_Closed">
                    <MenuItem x:Name="MenuOpen" Header="Open" Click="Open_Click" FontWeight="SemiBold">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.arrow-right}"
                                  Stroke="{StaticResource AccentBright}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuOpenNewTab" Header="Open in new tab" Click="OpenNewTab_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.plus}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuOpenWith" Header="Open with…" Click="OpenWith_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.external-link}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuOpenTerminal" Header="Open in Terminal" Click="OpenTerminal_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.terminal}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem x:Name="MenuCut" Header="Cut" InputGestureText="Ctrl+X" Click="Cut_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.scissors}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuCopy" Header="Copy" InputGestureText="Ctrl+C" Click="Copy_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.copy}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuCopyPath" Header="Copy as path" Click="CopyPath_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.hash}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuPaste" Header="Paste" InputGestureText="Ctrl+V" Click="Paste_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.clipboard}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem x:Name="MenuCompress" Header="Compress to ZIP" Click="Compress_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.package}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuExtract" Header="Extract here" Click="Extract_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.archive}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuShortcut" Header="Create shortcut" Click="CreateShortcut_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.link}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuPin" Header="Pin to Quick Access" Click="Pin_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.star}"
                                  Stroke="{StaticResource AccentBright}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem x:Name="MenuRename" Header="Rename" InputGestureText="F2" Click="Rename_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.pencil}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuDelete" Header="Delete" InputGestureText="Del" Click="Delete_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.trash}"
                                  Stroke="{StaticResource Danger}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem x:Name="MenuNewFolder" Header="New folder" Click="NewFolder_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.folder-plus}"
                                  Stroke="{StaticResource AccentBright}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MenuNewFile" Header="New text file" Click="NewTextFile_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.file-plus}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem x:Name="MenuProperties" Header="Properties" InputGestureText="Alt+Enter" Click="Properties_Click">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.info}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem x:Name="MenuShowMore" Header="Show more options"
                              SubmenuOpened="ShowMore_SubmenuOpened">
                        <MenuItem.Icon>
                            <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.list}"
                                  Stroke="{StaticResource TextMuted}" />
                        </MenuItem.Icon>
                        <MenuItem Header="Loading…" IsEnabled="False" />
                    </MenuItem>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource ColumnHeaderStyle}">
                    <GridViewColumn x:Name="ColName" Header="Name" Width="380">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox VerticalAlignment="Center" Margin="0,0,8,0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay,
                                                  RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                              Visibility="{Binding Source={x:Static svc:SettingsStore.Instance},
                                                  Path=Settings.ShowCheckboxes, Converter={StaticResource BoolToVis}}" />
                                    <Path Style="{StaticResource IconPath}" Width="17" Height="17" StrokeThickness="1.7"
                                          Margin="0,0,10,0" VerticalAlignment="Center"
                                          Data="{Binding IconKey, Converter={StaticResource IconGeom}}"
                                          Stroke="{Binding IconBrush}" />
                                    <!-- Display mode -->
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                               Foreground="{StaticResource Text}"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding IsEditing,
                                                   Converter={StaticResource InverseBoolToVis}}" />
                                    <!-- Inline-rename mode -->
                                    <TextBox Style="{StaticResource InlineEditBox}"
                                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             MinWidth="160" Height="24" VerticalAlignment="Center"
                                             Visibility="{Binding IsEditing,
                                                 Converter={StaticResource BoolToVis}}"
                                             IsVisibleChanged="RenameBox_IsVisibleChanged"
                                             KeyDown="RenameBox_KeyDown"
                                             LostKeyboardFocus="RenameBox_LostKeyboardFocus" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ColDate" Header="Date modified" Width="158">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ModifiedText}" Style="{StaticResource MetaCell}"
                                           FontFamily="{StaticResource MonoFont}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ColCreated" Header="Date created" Width="158">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CreatedText}" Style="{StaticResource MetaCell}"
                                           FontFamily="{StaticResource MonoFont}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ColType" Header="Type" Width="116">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TypeLabel}" Style="{StaticResource MetaCell}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ColSize" Header="Size" Width="92">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SizeText}" Style="{StaticResource MetaCell}"
                                           FontFamily="{StaticResource MonoFont}" HorizontalAlignment="Right"
                                           TextAlignment="Right" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Rubber-band selection rectangle (drawn over the list; never hit-tested) -->
        <Canvas x:Name="MarqueeLayer" IsHitTestVisible="False">
            <Border x:Name="Marquee" Visibility="Collapsed" CornerRadius="2"
                    Background="{StaticResource AccentWash2}"
                    BorderBrush="{StaticResource AccentLine}" BorderThickness="1" />
        </Canvas>
            </Grid>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="{StaticResource Line1}"
                          DragCompleted="PreviewSplitter_DragCompleted"
                          Visibility="{Binding Source={x:Static svc:SettingsStore.Instance},
                              Path=Settings.ShowPreviewPane, Converter={StaticResource BoolToVis}}" />
            <ctrl:PreviewPane Grid.Column="2" x:Name="Preview"
                          Visibility="{Binding Source={x:Static svc:SettingsStore.Instance},
                              Path=Settings.ShowPreviewPane, Converter={StaticResource BoolToVis}}" />
        </Grid>
        </Grid>

        <!-- Status bar (toggleable via settings) -->
        <Border Grid.Row="3" Height="28" Background="{StaticResource Glass2}"
                DataContext="{Binding SelectedTab}"
                BorderBrush="{StaticResource Line1}" BorderThickness="0,1,0,0"
                Visibility="{Binding Source={x:Static svc:SettingsStore.Instance},
                    Path=Settings.ShowStatusBar, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextMuted}"
                       VerticalAlignment="Center" Margin="14,0" FontSize="12" />
        </Border>
    </Grid>
</UserControl>
