<UserControl
    x:Class="RainExplorer.Controls.BreadcrumbBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="30" Focusable="False">

    <UserControl.Resources>
        <!-- Dropdown row: folder icon + name (used by the chevron + autocomplete popups) -->
        <DataTemplate x:Key="DropItemTemplate">
            <StackPanel Orientation="Horizontal" Margin="2,1">
                <Path Style="{StaticResource IconPath}" Width="15" Height="15" StrokeThickness="1.7"
                      Margin="2,0,9,0" VerticalAlignment="Center" Data="{StaticResource Ic.folder}"
                      Stroke="{StaticResource AccentBright}" />
                <TextBlock Text="{Binding Display}" VerticalAlignment="Center"
                           Foreground="{StaticResource Text}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="DropItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="Transparent" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Glass3}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentWash}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DropListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DropItemStyle}" />
            <Setter Property="ItemTemplate" Value="{StaticResource DropItemTemplate}" />
        </Style>

        <!-- A single path segment -->
        <Style x:Key="CrumbButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextDim}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Glass3}" />
                                <Setter Property="Foreground" Value="{StaticResource Text}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The chevron that opens a segment's subfolder list -->
        <Style x:Key="CrumbChevronStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4" Height="22">
                            <Path Width="8" Height="8" Stretch="Uniform" Data="{StaticResource Ic.chevron-right}"
                                  Stroke="{StaticResource TextFaint}" StrokeThickness="2"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Glass3}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ===== Breadcrumb mode ===== -->
        <Border x:Name="CrumbHost" Background="{StaticResource Glass2}"
                BorderBrush="{StaticResource Line2}" BorderThickness="1" CornerRadius="8" Height="30"
                MouseLeftButtonDown="CrumbHost_MouseDown">
            <ScrollViewer x:Name="CrumbScroll" Padding="6,0"
                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="CrumbStrip" Orientation="Horizontal" VerticalAlignment="Center" />
            </ScrollViewer>
        </Border>

        <!-- ===== Edit mode (raw path text) ===== -->
        <Border x:Name="EditHost" Visibility="Collapsed" Background="{StaticResource Glass2}"
                BorderBrush="{StaticResource AccentLine}" BorderThickness="1" CornerRadius="8"
                Height="30" Padding="12,0,10,0">
            <DockPanel LastChildFill="True">
                <Path DockPanel.Dock="Left" Style="{StaticResource IconPath}" Width="14" Height="14"
                      Margin="0,0,8,0" VerticalAlignment="Center"
                      Data="{StaticResource Ic.hard-drive}" Stroke="{StaticResource AccentBright}" />
                <TextBox x:Name="EditBox" BorderThickness="0" Background="Transparent"
                         Foreground="{StaticResource Text}" CaretBrush="{StaticResource AccentBright}"
                         SelectionBrush="{StaticResource AccentWash2}"
                         FontFamily="{StaticResource MonoFont}" FontSize="12"
                         VerticalContentAlignment="Center"
                         TextChanged="EditBox_TextChanged"
                         PreviewKeyDown="EditBox_PreviewKeyDown"
                         LostKeyboardFocus="EditBox_LostKeyboardFocus" />
            </DockPanel>
        </Border>

        <!-- ===== Shared dropdown popups ===== -->
        <!-- Subfolder list anchored to a crumb chevron (PlacementTarget set in code) -->
        <Popup x:Name="ChildPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
               PopupAnimation="Fade" VerticalOffset="4">
            <Border Background="{StaticResource MenuBg}" BorderBrush="{StaticResource Line2}" BorderThickness="1"
                    CornerRadius="10" Padding="5" MinWidth="220" MaxWidth="440">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="24" ShadowDepth="5" />
                </Border.Effect>
                <ListBox x:Name="ChildList" Style="{StaticResource DropListStyle}" MaxHeight="360"
                         PreviewMouseLeftButtonDown="ChildList_MouseDown" />
            </Border>
        </Popup>

        <!-- Autocomplete suggestions under the edit box -->
        <Popup x:Name="AcPopup" PlacementTarget="{Binding ElementName=EditHost}" Placement="Bottom"
               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="4">
            <Border Background="{StaticResource MenuBg}" BorderBrush="{StaticResource Line2}" BorderThickness="1"
                    CornerRadius="10" Padding="5" MinWidth="300" MaxWidth="640">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="24" ShadowDepth="5" />
                </Border.Effect>
                <ListBox x:Name="AcList" Style="{StaticResource DropListStyle}" MaxHeight="320"
                         PreviewMouseLeftButtonDown="AcList_MouseDown" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
