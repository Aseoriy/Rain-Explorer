<Window
    x:Class="RainExplorer.Views.PropertiesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="600" Height="640"
    WindowStyle="None" AllowsTransparency="True" Background="Transparent"
    ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
    FontFamily="{DynamicResource AppFont}" FontSize="13" Foreground="{StaticResource Text}">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- Left-nav tab (icon + label) -->
        <Style x:Key="PropNav" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextDim}" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="bg" Background="Transparent" CornerRadius="8"
                                    BorderBrush="Transparent" BorderThickness="1" Padding="10,8">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="bar" Width="3" Height="16" CornerRadius="2"
                                    HorizontalAlignment="Left" Background="{StaticResource GradientAccent}"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource Glass3}" />
                                <Setter Property="Foreground" Value="{StaticResource Text}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource AccentWash}" />
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentLine}" />
                                <Setter TargetName="bar" Property="Visibility" Value="Visible" />
                                <Setter Property="Foreground" Value="{StaticResource Text}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F2161620" BorderBrush="{StaticResource Line2}"
            BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.62" BlurRadius="32" ShadowDepth="5" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Height="44" Background="{StaticResource Glass2}"
                  MouseLeftButtonDown="Title_Drag">
                <Border BorderBrush="{StaticResource Line1}" BorderThickness="0,0,0,1" CornerRadius="12,12,0,0" />
                <TextBlock Text="Properties" FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center" Margin="18,0" Foreground="{StaticResource Text}" />
                <Button Style="{StaticResource CloseButton}" HorizontalAlignment="Right" Margin="0,0,7,0"
                        Width="34" Height="30" Click="Cancel_Click" ToolTip="Close">
                    <Path Style="{StaticResource IconPath}" Width="15" Height="15" Data="{StaticResource Ic.x}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Button>
            </Grid>

            <!-- Body: nav + content -->
            <Grid Grid.Row="1" Margin="14,14,16,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ListBox x:Name="NavList" Grid.Column="0" Background="Transparent" BorderThickness="0"
                         SelectedIndex="0" ItemContainerStyle="{StaticResource PropNav}"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Width="16" Height="16" Margin="0,0,11,0"
                                  Data="{StaticResource Ic.info}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                            <TextBlock Text="General" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Width="16" Height="16" Margin="0,0,11,0"
                                  Data="{StaticResource Ic.list}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                            <TextBlock Text="Details" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Width="16" Height="16" Margin="0,0,11,0"
                                  Data="{StaticResource Ic.hash}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                            <TextBlock Text="Hashes" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <Grid Grid.Column="1" Margin="8,0,0,0">
                    <!-- ===== GENERAL ===== -->
                    <ScrollViewer x:Name="PaneGeneral" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
                        <StackPanel>
                            <!-- Header: icon + editable name -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="11"
                                        Background="{StaticResource Glass3}" BorderBrush="{StaticResource Line2}"
                                        BorderThickness="1" VerticalAlignment="Center">
                                    <Path x:Name="GlyphIcon" Style="{StaticResource IconPath}" Width="26" Height="26"
                                          StrokeThickness="1.7" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Name" Foreground="{StaticResource TextFaint}" FontSize="11"
                                               FontWeight="Bold" Margin="2,0,0,5" />
                                    <TextBox x:Name="NameBox" Style="{StaticResource FieldBox}" Height="32" />
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{StaticResource Line1}" Margin="0,16" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Type" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TypeText" Style="{StaticResource FieldValue}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Location" Style="{StaticResource FieldLabel}" />
                                <Grid Grid.Row="1" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" x:Name="LocationText" Style="{StaticResource FieldValue}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="12" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="6,3,0,0">
                                        <Button Style="{StaticResource IconButton}" Width="26" Height="26" Click="CopyPath_Click"
                                                ToolTip="Copy full path">
                                            <Path Style="{StaticResource IconPath}" Width="14" Height="14" Data="{StaticResource Ic.copy}"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" Width="26" Height="26" Click="OpenLocation_Click"
                                                ToolTip="Open containing folder">
                                            <Path Style="{StaticResource IconPath}" Width="14" Height="14" Data="{StaticResource Ic.external-link}"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Size" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SizeText" Style="{StaticResource FieldValue}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Size on disk" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SizeOnDiskText" Style="{StaticResource FieldValue}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12" />

                                <TextBlock Grid.Row="4" Grid.Column="0" x:Name="ContainsLabel" Text="Contains"
                                           Style="{StaticResource FieldLabel}" Visibility="Collapsed" />
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ContainsText" Style="{StaticResource FieldValue}"
                                           Visibility="Collapsed" />

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Created" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="CreatedText" Style="{StaticResource FieldValue}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12" />

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Modified" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="ModifiedText" Style="{StaticResource FieldValue}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12" />

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Accessed" Style="{StaticResource FieldLabel}" />
                                <TextBlock Grid.Row="7" Grid.Column="1" x:Name="AccessedText" Style="{StaticResource FieldValue}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12" />
                            </Grid>

                            <Border Height="1" Background="{StaticResource Line1}" Margin="0,16" />

                            <TextBlock Text="ATTRIBUTES" Foreground="{StaticResource TextFaint}" FontSize="11"
                                       FontWeight="Bold" Margin="0,0,0,10" />
                            <WrapPanel>
                                <CheckBox x:Name="ReadOnlyCheck" Content="Read-only" Margin="0,0,20,8" />
                                <CheckBox x:Name="HiddenCheck" Content="Hidden" Margin="0,0,20,8" />
                                <CheckBox x:Name="ArchiveCheck" Content="Archive" Margin="0,0,20,8" />
                                <TextBlock x:Name="SystemNote" Text="· System" Foreground="{StaticResource TextFaint}"
                                           VerticalAlignment="Center" Margin="0,0,0,8" Visibility="Collapsed" />
                            </WrapPanel>

                            <TextBlock x:Name="ErrorText" Foreground="{StaticResource Danger}" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,8,0,0" Visibility="Collapsed" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ===== DETAILS ===== -->
                    <ScrollViewer x:Name="PaneDetails" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
                        <StackPanel x:Name="DetailsPanel" />
                    </ScrollViewer>

                    <!-- ===== HASHES ===== -->
                    <ScrollViewer x:Name="PaneHashes" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="CHECKSUMS" Foreground="{StaticResource TextFaint}" FontSize="11"
                                       FontWeight="Bold" Margin="0,2,0,12" />

                            <Grid x:Name="HashGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="MD5" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="Md5Text" IsReadOnly="True"
                                         Style="{StaticResource FieldBox}" Margin="0,4" Height="30"
                                         FontFamily="{StaticResource MonoFont}" FontSize="11" />
                                <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource IconButton}" Width="28" Height="28"
                                        Margin="6,4,0,4" Click="CopyHash_Click" Tag="md5" ToolTip="Copy MD5">
                                    <Path Style="{StaticResource IconPath}" Width="14" Height="14" Data="{StaticResource Ic.copy}"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Button>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="SHA-1" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="Sha1Text" IsReadOnly="True"
                                         Style="{StaticResource FieldBox}" Margin="0,4" Height="30"
                                         FontFamily="{StaticResource MonoFont}" FontSize="11" />
                                <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource IconButton}" Width="28" Height="28"
                                        Margin="6,4,0,4" Click="CopyHash_Click" Tag="sha1" ToolTip="Copy SHA-1">
                                    <Path Style="{StaticResource IconPath}" Width="14" Height="14" Data="{StaticResource Ic.copy}"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Button>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="SHA-256" Style="{StaticResource FieldLabel}" />
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="Sha256Text" IsReadOnly="True"
                                         Style="{StaticResource FieldBox}" Margin="0,4" Height="30"
                                         FontFamily="{StaticResource MonoFont}" FontSize="11" />
                                <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource IconButton}" Width="28" Height="28"
                                        Margin="6,4,0,4" Click="CopyHash_Click" Tag="sha256" ToolTip="Copy SHA-256">
                                    <Path Style="{StaticResource IconPath}" Width="14" Height="14" Data="{StaticResource Ic.copy}"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Button>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button x:Name="HashButton" Content="Compute hashes" Style="{StaticResource DialogButton}"
                                        Click="ComputeHashes_Click" />
                                <TextBlock x:Name="HashStatus" VerticalAlignment="Center" Margin="14,0,0,0"
                                           Foreground="{StaticResource TextMuted}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource Glass2}" BorderBrush="{StaticResource Line1}"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,12,12" Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource GhostButton}" IsCancel="True"
                            Click="Cancel_Click" Margin="0,0,8,0" />
                    <Button Content="Save changes" Style="{StaticResource PrimaryButton}" IsDefault="True"
                            Click="Save_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
