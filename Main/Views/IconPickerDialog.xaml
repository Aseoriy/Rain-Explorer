<Window
    x:Class="RainExplorer.Views.IconPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="420" SizeToContent="Height"
    WindowStyle="None" AllowsTransparency="True" Background="Transparent"
    ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
    FontFamily="{DynamicResource AppFont}" FontSize="13" Foreground="{StaticResource Text}">

    <Window.Resources>
        <!-- A selectable icon swatch -->
        <Style x:Key="IconSwatch" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Width="46" Height="46" CornerRadius="9"
                                Background="{StaticResource Glass2}"
                                BorderBrush="{StaticResource Line2}" BorderThickness="1">
                            <Path Style="{StaticResource IconPath}" Width="20" Height="20"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="{Binding Converter={StaticResource IconGeom}}"
                                  Stroke="{StaticResource TextDim}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Line3}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentWash}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AccentLine}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F216161F" BorderBrush="{StaticResource Line2}"
            BorderThickness="1" CornerRadius="12" Padding="18">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.62" BlurRadius="32" ShadowDepth="5" />
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="Choose an icon" FontSize="15" FontWeight="SemiBold"
                       MouseLeftButtonDown="Title_Drag" />
            <ListBox x:Name="IconList" Margin="0,14,0,0" Background="Transparent" BorderThickness="0"
                     MaxHeight="300" ItemContainerStyle="{StaticResource IconSwatch}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     MouseDoubleClick="IconList_MouseDoubleClick">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Style="{StaticResource DialogButton}" IsCancel="True"
                        Click="Cancel_Click" Margin="0,0,8,0" />
                <Button Content="Use icon" Style="{StaticResource PrimaryButton}" IsDefault="True"
                        Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
