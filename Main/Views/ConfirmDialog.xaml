<Window
    x:Class="RainExplorer.Views.ConfirmDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="420" SizeToContent="Height"
    WindowStyle="None" AllowsTransparency="True" Background="Transparent"
    ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
    FontFamily="{DynamicResource AppFont}" FontSize="13" Foreground="{StaticResource Text}">

    <Border Background="#F216161F" BorderBrush="{StaticResource Line2}"
            BorderThickness="1" CornerRadius="12" Padding="18">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.62" BlurRadius="32" ShadowDepth="5" />
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal" MouseLeftButtonDown="Title_Drag">
                <Path x:Name="Glyph" Style="{StaticResource IconPath}" Width="20" Height="20"
                      Data="{StaticResource Ic.trash}" Stroke="{StaticResource Danger}"
                      VerticalAlignment="Center" />
                <TextBlock x:Name="TitleText" FontSize="15" FontWeight="SemiBold"
                           Margin="10,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock x:Name="MessageText" Foreground="{StaticResource TextDim}"
                       Margin="0,12,0,4" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource DialogButton}"
                        IsCancel="True" Click="Cancel_Click" Margin="0,0,8,0" />
                <Button x:Name="OkButton" Content="OK" Style="{StaticResource PrimaryButton}"
                        IsDefault="True" Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
