<Window
    x:Class="RainExplorer.Views.InputDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="400" SizeToContent="Height"
    WindowStyle="None" AllowsTransparency="True" Background="Transparent"
    ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
    FontFamily="Segoe UI" FontSize="13" Foreground="{StaticResource Text}">

    <Border Background="#F216161F" BorderBrush="{StaticResource Line2}"
            BorderThickness="1" CornerRadius="12" Padding="18">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.62" BlurRadius="32" ShadowDepth="5" />
        </Border.Effect>
        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="15" FontWeight="SemiBold"
                       MouseLeftButtonDown="Title_Drag" />
            <TextBlock x:Name="PromptText" Foreground="{StaticResource TextDim}" Margin="0,10,0,4" />
            <TextBox x:Name="Input" Style="{StaticResource FieldBox}" Height="32" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Style="{StaticResource DialogButton}" IsCancel="True"
                        Click="Cancel_Click" Margin="0,0,8,0" />
                <Button Content="OK" Style="{StaticResource PrimaryButton}" IsDefault="True"
                        Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
